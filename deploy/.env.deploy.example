# Copy to deploy/.env.deploy — docker compose: --env-file deploy/.env.deploy
#
# KEMRI tree defaults below point at local KEMRI ports (8184 / API 3102). Do not uncomment Machakos
# production URLs unless you intentionally deploy this codebase to that host.

# Machakos production (REFERENCE ONLY — do not use for KEMRI local dev):
# MACHAKOS_PUBLIC_URL=https://monitoring.icskenya.co.ke
# MACHAKOS_CITIZEN_PUBLIC_URL=https://monitoring.icskenya.co.ke/citizen
# MACHAKOS_API_PROXY=http://host.docker.internal:3002

MACHAKOS_PUBLIC_URL=http://localhost:8184
MACHAKOS_CITIZEN_PUBLIC_URL=http://localhost:8184/citizen
MACHAKOS_API_PROXY=http://host.docker.internal:3102

# Required for production maps (baked in at image build). Same key as local VITE_MAPS_API_KEY.
# If the map shows "For development purposes only", enable billing on the Google Cloud project
# and ensure "Maps JavaScript API" is on; restrict the key by HTTP referrer to your domains.
# For GIS search-as-you-type, also enable "Places API" (same project/key) or the map overlay can appear when typing.
# VITE_MAPS_API_KEY=
