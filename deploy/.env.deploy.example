# Copy to deploy/.env.deploy — docker compose: --env-file deploy/.env.deploy
#
# Variable names are MACHAKOS_* for historical reasons (this code was cloned
# from a Machakos-county app); they apply equally to KEMRI deployments.

# ── KEMRI production (kemri.pathwaystechnologies.com) ────────────────────────
# Uncomment when deploying to the public subdomain.
# MACHAKOS_PUBLIC_URL=https://kemri.pathwaystechnologies.com
# MACHAKOS_CITIZEN_PUBLIC_URL=https://kemri.pathwaystechnologies.com/citizen
# MACHAKOS_API_PROXY=http://host.docker.internal:3102

# ── Local development (KEMRI ports: 8184 / API 3102) ─────────────────────────
MACHAKOS_PUBLIC_URL=http://localhost:8184
MACHAKOS_CITIZEN_PUBLIC_URL=http://localhost:8184/citizen
MACHAKOS_API_PROXY=http://host.docker.internal:3102

# Required for production maps (baked in at image build). Same key as local VITE_MAPS_API_KEY.
# If the map shows "For development purposes only", enable billing on the Google Cloud project
# and ensure "Maps JavaScript API" is on; restrict the key by HTTP referrer to your domains.
# For GIS search-as-you-type, also enable "Places API" (same project/key).
# VITE_MAPS_API_KEY=
